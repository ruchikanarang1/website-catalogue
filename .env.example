# Supabase Configuration (same project for all clients)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Company ID — get this from the ERP (companies table in Supabase)
# Each website deployment gets a different VITE_COMPANY_ID
VITE_COMPANY_ID=your-company-uuid-here
